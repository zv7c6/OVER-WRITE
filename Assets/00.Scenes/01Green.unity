    choicePanelPosition: {x: -453, y: 177}
    isEnding: 0
  - dialogue: "\uC194\uC9C1\uD788 \uB098\uB3C4 \uC798 \uBAB0\uB77C.\n\uB09C \uB300\uBCF8\uC744
